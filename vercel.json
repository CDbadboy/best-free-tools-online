{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "assets/**/*", "use": "@vercel/static" },
    { "src": "tools.json", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www\\.bestfreetoolsonline\\.com" }], "destination": "https://bestfreetoolsonline.com/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "best-free-tools-online.*\\.vercel\\.app" }], "destination": "https://bestfreetoolsonline.com/$1", "permanent": true }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/tools.json", "dest": "/tools.json" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
